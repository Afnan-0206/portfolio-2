# Environment Variables
# Copy this file to .env.local and update values as needed

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Scrollytelling Portfolio

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Contact Form (Optional)
NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your-form-id
NEXT_PUBLIC_EMAIL_TO=your-email@example.com

# Social Links (Optional)
NEXT_PUBLIC_TWITTER=https://twitter.com/yourhandle
NEXT_PUBLIC_GITHUB=https://github.com/yourhandle
NEXT_PUBLIC_LINKEDIN=https://linkedin.com/in/yourprofile
